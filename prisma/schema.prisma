generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------
// Enums
// -----------------------------------------------------
enum FundMarket {
  INDIA
  USA
  INTERNATIONAL
}

// -----------------------------------------------------
// Core models
// -----------------------------------------------------

model Fund {
  id            String      @id @default(cuid())
  schemeCode    String      @unique
  name          String
  category      String      @default("Equity")
  subCategory   String      @default("")
  amcName       String      @default("")
  market        FundMarket   @default(INDIA)
  currency      String      @default("INR")
  nav           Float       @default(0)
  navDate       DateTime?
  prevNav       Float?
  changePercent Float?
  aum           Float?
  expenseRatio  Float?
  minInvestment Float?
  isActive      Boolean     @default(true)
  lastSyncedAt  DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  history       NavHistory[]

  @@index([market, category])
  @@index([changePercent])
}

model NavHistory {
  id    String   @id @default(cuid())
  fundId String
  nav   Float
  date  DateTime
  fund  Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, date])
  @@index([fundId, date])
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String   // 'MFAPI' | 'AMFI' | 'ALPHA_VANTAGE'
  status    String   // 'SUCCESS' | 'PARTIAL' | 'FAILED'
  fundsSync Int      @default(0)
  errors    String[]
  duration  Int      // ms
  createdAt DateTime @default(now())
}

// -----------------------------------------------------
// Existing application models (unchanged)
// -----------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(INVESTOR)
  kycStatus     KycStatus @default(NOT_STARTED)
  riskProfile   RiskProfile?
  accounts      Account[]
  sessions      Session[]
  portfolios    Portfolio[]
  transactions  Transaction[]
  watchlist     Watchlist[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/* Existing models (Account, Session, VerificationToken, Portfolio, Holding, Transaction, Watchlist, RiskProfile, etc.) remain unchanged. */

enum UserRole {
  INVESTOR
  ADVISOR
  AMC
  ADMIN
  RESEARCHER
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  BUY
  SELL
  SIP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RiskCategory {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}
