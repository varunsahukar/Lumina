// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTOR
  ADVISOR
  AMC
  ADMIN
  RESEARCHER
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  BUY
  SELL
  SIP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RiskCategory {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

enum FundMarket {
  INDIA
  USA
  INTERNATIONAL
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole      @default(INVESTOR)
  kycStatus     KycStatus     @default(NOT_STARTED)
  riskProfile   RiskProfile?
  accounts      Account[]
  sessions      Session[]
  portfolios    Portfolio[]
  transactions  Transaction[]
  watchlist     Watchlist[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Fund {
  id             String        @id @default(cuid())
  schemeCode     String        @unique
  name           String
  category       String        @default("Equity")
  subCategory    String        @default("")
  amcName        String        @default("")
  market         FundMarket    @default(INDIA)
  currency       String        @default("INR")
  nav            Float         @default(0)
  navDate        DateTime?
  prevNav        Float?
  changePercent  Float?
  aum            Float?
  expenseRatio   Float?
  minInvestment  Float?
  sharpeRatio    Float?
  alpha          Float?
  beta           Float?
  stdDeviation   Float?
  returns1y      Float?
  returns3y      Float?
  returns5y      Float?
  returns10y     Float?
  managerName    String?
  launchDate     DateTime?
  benchmarkIndex String?
  isActive       Boolean       @default(true)
  lastSyncedAt   DateTime?
  history        NavHistory[]
  holdings       Holding[]
  transactions   Transaction[]
  watchlist      Watchlist[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([market, category])
  @@index([changePercent])
}

model NavHistory {
  id     String   @id @default(cuid())
  fundId String
  nav    Float
  date   DateTime
  fund   Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@unique([fundId, date])
  @@index([fundId, date])
}

model SyncLog {
  id        String   @id @default(cuid())
  source    String
  status    String
  fundsSync Int      @default(0)
  errors    String[]
  duration  Int
  createdAt DateTime @default(now())
}

model Portfolio {
  id        String    @id @default(cuid())
  userId    String
  name      String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings  Holding[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Holding {
  id             String    @id @default(cuid())
  portfolioId    String
  fundId         String
  units          Decimal   @db.Decimal(12, 4)
  avgNav         Decimal   @db.Decimal(12, 4)
  investedAmount Decimal   @db.Decimal(12, 2)
  purchaseDate   DateTime?
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund           Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  fundId    String
  type      TransactionType
  amount    Decimal           @db.Decimal(12, 2)
  units     Decimal           @db.Decimal(12, 4)
  nav       Decimal           @db.Decimal(12, 4)
  date      DateTime
  status    TransactionStatus @default(COMPLETED)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund      Fund              @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  fundId    String
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, fundId])
}

model RiskProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  score       Int
  category    RiskCategory
  answers     Json
  completedAt DateTime
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}
