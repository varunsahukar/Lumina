# App
PORT=3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/lumina
JWT_SECRET=replace_with_secure_secret

# Indian Mutual Funds (no key needed)
MFAPI_BASE_URL=https://api.mfapi.in/mf
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt
INDIA_SYNC_CONCURRENCY=5
INDIA_SCHEME_CODES=119598,120503,120465,120594,118989,120716,125354,120828,120505,120822

# USA Mutual Funds
ALPHA_VANTAGE_KEY=your_key_here
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query
USA_TICKERS=VFIAX,FXAIX,VTSAX,FCNTX,VWELX,VTSMX,AGTHX,PRGFX
USA_SYNC_INTERVAL_MS=12000

# Feature flags
ENABLE_YAHOO_FINANCE=false
ENABLE_WEBSOCKET_PRICES=false
RAPIDAPI_KEY=your_key_here

# Redis
ENABLE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379

# Cron schedules
AMFI_SYNC_CRON=30 23 * * *
USA_SYNC_CRON=0 */4 * * *
