// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  INVESTOR
  ADVISOR
  AMC
  ADMIN
  RESEARCHER
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum TransactionType {
  BUY
  SELL
  SIP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum RiskCategory {
  CONSERVATIVE
  MODERATE
  AGGRESSIVE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(INVESTOR)
  kycStatus     KycStatus @default(NOT_STARTED)
  riskProfile   RiskProfile?
  accounts      Account[]
  sessions      Session[]
  portfolios    Portfolio[]
  transactions  Transaction[]
  watchlist     Watchlist[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Fund {
  id             String   @id @default(cuid())
  schemeCode     String   @unique
  schemeName     String
  amcName        String
  category       String
  subCategory    String?
  nav            Decimal  @db.Decimal(12, 4)
  aum            Decimal? @db.Decimal(15, 2)
  expenseRatio   Decimal? @db.Decimal(5, 4)
  sharpeRatio    Decimal? @db.Decimal(6, 4)
  alpha          Decimal? @db.Decimal(6, 4)
  beta           Decimal? @db.Decimal(6, 4)
  stdDeviation   Decimal? @db.Decimal(6, 4)
  returns1y      Decimal? @db.Decimal(10, 4)
  returns3y      Decimal? @db.Decimal(10, 4)
  returns5y      Decimal? @db.Decimal(10, 4)
  returns10y     Decimal? @db.Decimal(10, 4)
  managerName    String?
  launchDate     DateTime?
  benchmarkIndex String?
  isActive       Boolean  @default(true)
  navHistory     NavHistory[]
  holdings       Holding[]
  transactions   Transaction[]
  watchlist      Watchlist[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NavHistory {
  id        String   @id @default(cuid())
  fundId    String
  nav       Decimal  @db.Decimal(12, 4)
  date      DateTime
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([fundId, date])
}

model Portfolio {
  id         String    @id @default(cuid())
  userId     String
  name       String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  holdings   Holding[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Holding {
  id             String    @id @default(cuid())
  portfolioId    String
  fundId         String
  units          Decimal   @db.Decimal(12, 4)
  avgNav         Decimal   @db.Decimal(12, 4)
  investedAmount Decimal   @db.Decimal(12, 2)
  purchaseDate   DateTime?
  portfolio      Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  fund           Fund      @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Transaction {
  id        String            @id @default(cuid())
  userId    String
  fundId    String
  type      TransactionType
  amount    Decimal           @db.Decimal(12, 2)
  units     Decimal           @db.Decimal(12, 4)
  nav       Decimal           @db.Decimal(12, 4)
  date      DateTime
  status    TransactionStatus @default(COMPLETED)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund      Fund              @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime          @default(now())
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  fundId    String
  addedAt   DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fund      Fund     @relation(fields: [fundId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, fundId])
}

model RiskProfile {
  id           String        @id @default(cuid())
  userId       String        @unique
  score        Int
  category     RiskCategory
  answers      Json
  completedAt  DateTime
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}
